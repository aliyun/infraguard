{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "'", "close": "'" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "'", "close": "'" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\S.*:\\s*(?:#.*)?$",
    "decreaseIndentPattern": "^\\s+\\}$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\S.*:\\s*(?:#.*)?$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*- ",
      "action": {
        "indent": "none"
      }
    }
  ],
  "folding": {
    "offSide": true
  }
}
